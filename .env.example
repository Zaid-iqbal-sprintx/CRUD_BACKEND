# Copy this file to ".env" and fill in your real values.
# .env is gitignored — never commit real credentials.

# Port the Express server listens on
PORT=5001

# MongoDB Atlas connection string.
# Get it from: Atlas dashboard > Connect > Drivers > copy the URI.
# Replace <username>, <password>, and the cluster host with your own,
# and put your database name after the host (here: "taskmanager").
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/taskmanager?retryWrites=true&w=majority

# Allowed CORS origin for the browser frontend.
# Leave unset (or "*") to allow any origin during development; set it to your
# frontend URL in production, e.g. http://localhost:3000
CORS_ORIGIN=*
